{
  "kind": "collectionType",
  "collectionName": "reservations",
  "info": {
    "singularName": "reservation",
    "pluralName": "reservations",
    "displayName": "reservation"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "first_name": {
      "type": "string",
      "required": true
    },
    "last_name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "date": {
      "type": "datetime"
    },
    "time": {
      "type": "string",
      "required": true
    },
    "guests": {
      "type": "integer",
      "required": true
    },
    "special_requests": {
      "type": "text"
    },
    "statut": {
      "type": "enumeration",
      "enum": [
        "pending",
        "confirmed",
        "cancelled",
        "no_show"
      ]
    },
    "message": {
      "type": "text"
    }
  }
}
